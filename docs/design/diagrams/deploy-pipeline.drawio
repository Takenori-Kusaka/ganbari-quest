        </mxCell>
        <mxCell id="p2-migrate" value="2. 手動: DB Migration&#xa;(deploy-nuc.yml外&#xa;必要時のみ実行)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
