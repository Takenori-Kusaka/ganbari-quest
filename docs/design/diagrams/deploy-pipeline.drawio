        </mxCell>
        <mxCell id="p2-stop" value="1. docker&#xa;compose stop&#xa;(WAL flush)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
