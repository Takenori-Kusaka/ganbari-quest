        <!-- Note -->
        <mxCell id="p1-note" value="ブランチ保護: main への直 push 禁止&#xa;Draft PR → CI 全通過 → Ready → レビュー → マージ → 自動デプロイ" style="text;html=1;align=left;verticalAlign=top;strokeColor=#999;fillColor=#FAFAFA;rounded=1;fontSize=10;" vertex="1" parent="p1-group">
