        </mxCell>
        <mxCell id="p2-pull" value="3. git pull&#xa;最新コード取得" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
          <mxGeometry x="500" y="40" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2-build" value="4. docker&#xa;compose build&#xa;(x86_64)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
          <mxGeometry x="650" y="40" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2-up" value="5. docker&#xa;compose up -d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
