        <mxCell id="p3-e2b" style="strokeColor=#333;strokeWidth=1;" edge="1" source="p3-unit" target="p3-gate" parent="p3-group"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e2c" style="strokeColor=#333;strokeWidth=1;" edge="1" source="p3-e2e" target="p3-gate" parent="p3-group"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e2d" style="strokeColor=#333;strokeWidth=1;" edge="1" source="p3-docker-check" target="p3-gate" parent="p3-group"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-e2e2" style="strokeColor=#333;strokeWidth=1;" edge="1" source="p3-codeql" target="p3-gate" parent="p3-group"><mxGeometry relative="1" as="geometry" /></mxCell>

