        <mxCell id="p2-sqlite" value="SQLite (WAL mode)&#xa;data/ganbari-quest.db" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
