        <mxCell id="p2-warn" value="⚠ 順序厳守: stop → migrate → build → up&#xa;docker compose up -d だけではWAL不整合でDB破損リスク (#0099)" style="text;html=1;align=left;verticalAlign=top;strokeColor=#F44336;fillColor=#FFEBEE;rounded=1;fontSize=10;fontColor=#B71C1C;" vertex="1" parent="p2-group">
