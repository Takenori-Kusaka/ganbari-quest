        <mxCell id="p2-ssh" value="SSH 接続&#xa;&lt;NUC_USER&gt;&#xa;@&lt;NUC_HOST&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
