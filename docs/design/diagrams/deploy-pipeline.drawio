        </mxCell>
        <mxCell id="p2-health" value="6. Health Check&#xa;curl localhost:3000&#xa;/api/health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;" vertex="1" parent="p2-group">
