{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 20 }
				},
				"useMaxParams": {
					"level": "warn",
					"options": { "max": 5 }
				}
			},
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noRedeclare": "warn",
				"noAssignInExpressions": "warn",
				"noConsole": {
					"level": "warn",
					"options": { "allow": ["warn", "error", "info"] }
				},
				"noImportCycles": "error"
			},
			"performance": {
				"noBarrelFile": "warn"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.svelte"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					},
					"style": {
						"useConst": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.css"],
			"linter": {
				"rules": {
					"complexity": {
						"noImportantStyles": "off"
					}
				}
			}
		}
	],
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.svelte-kit",
			"!**/build",
			"!**/coverage",
			"!**/test-results",
			"!**/test-results.json",
			"!**/playwright-report",
			"!**/*.db",
			"!**/site",
			"!**/cdk.out",
			"!**/storybook-static",
			"!**/app.css",
			"!**/.claude",
			"!**/*.md",
			"!infra/**",
			"!scripts/**"
		]
	}
}
