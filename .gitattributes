# Force LF line endings for all text files.
# Prevents CRLF/LF mismatch between Windows (autocrlf) and CI/formatter (LF).
# This setting is repository-level and applies to all clones automatically.
* text=auto eol=lf

# Ensure these are always treated as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
