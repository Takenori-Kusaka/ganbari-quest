{
	"name": "ganbari-quest",
	"private": true,
	"version": "1.0.0",
	"description": "がんばりクエスト - 子供の活動をゲーミフィケーションで動機付けする家庭内専用Webアプリ",
	"repository": {
		"type": "git",
		"url": "https://github.com/kokor-djp/ganbari-quest.git"
	},
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"version:generate": "tsx scripts/generate-version.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "vitest run && playwright test",
		"quality-gate": "biome check . && svelte-check --tsconfig ./tsconfig.json && vitest run --coverage && playwright test",
		"lint": "biome check . && eslint --no-error-on-unmatched-pattern 'src/**/*.svelte' && stylelint 'src/**/*.css'",
		"lint:svelte": "eslint --no-error-on-unmatched-pattern 'src/**/*.svelte'",
		"lint:css": "stylelint 'src/**/*.css'",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"deploy": "bash scripts/deploy.sh",
		"start": "node build/index.js",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@chromatic-com/storybook": "^5.1.1",
		"@google/genai": "^1.47.0",
		"@playwright/test": "^1.50.0",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/svelte": "^5.2.0",
		"@types/bcrypt": "^6.0.0",
		"@types/better-sqlite3": "^7.6.0",
		"@types/web-push": "^3.6.4",
		"@typescript-eslint/parser": "^8.58.0",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"drizzle-kit": "^0.30.0",
		"eslint": "^10.1.0",
		"eslint-plugin-storybook": "^10.3.4",
		"eslint-plugin-svelte": "^3.17.0",
		"jsdom": "^29.0.1",
		"playwright": "^1.59.1",
		"sharp": "^0.34.5",
		"storybook": "^10.3.4",
		"stylelint": "^17.6.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.55.0",
		"svelte-check": "^4.3.6",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.20.0",
		"@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
		"@aws-sdk/client-cost-explorer": "^3.1020.0",
		"@aws-sdk/client-dynamodb": "^3.1018.0",
		"@aws-sdk/client-s3": "^3.1018.0",
		"@aws-sdk/client-ses": "^3.1019.0",
		"@aws-sdk/lib-dynamodb": "^3.1018.0",
		"@google/generative-ai": "^0.24.1",
		"@types/qrcode": "^1.5.6",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.8.0",
		"drizzle-orm": "^0.45.1",
		"fflate": "^0.8.2",
		"googleapis": "^171.4.0",
		"jose": "^6.2.2",
		"qrcode": "^1.5.4",
		"stripe": "^21.0.0",
		"web-push": "^3.6.7",
		"zod": "^3.24.0"
	}
}
