{
	"name": "ganbari-quest",
	"private": true,
	"version": "1.0.0",
	"description": "がんばりクエスト - 子供の活動をゲーミフィケーションで動機付けする家庭内専用Webアプリ",
	"repository": {
		"type": "git",
		"url": "https://github.com/kokor-djp/ganbari-quest.git"
	},
	"license": "AGPL-3.0-only",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "vitest run && playwright test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"deploy": "bash scripts/deploy.sh",
		"start": "node build/index.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.50.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.0",
		"@testing-library/svelte": "^5.2.0",
		"@types/bcrypt": "^6.0.0",
		"@types/better-sqlite3": "^7.6.0",
		"@vitest/coverage-v8": "^3.0.0",
		"drizzle-kit": "^0.30.0",
		"jsdom": "^26.0.0",
		"sharp": "^0.34.5",
		"svelte": "^5.55.0",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.0",
		"tsx": "^4.19.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"@ark-ui/svelte": "^5.0.0",
		"@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
		"@aws-sdk/client-dynamodb": "^3.1011.0",
		"@aws-sdk/client-s3": "^3.1014.0",
		"@aws-sdk/lib-dynamodb": "^3.1018.0",
		"@google/generative-ai": "^0.24.1",
		"@types/qrcode": "^1.5.6",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^11.0.0",
		"drizzle-orm": "^0.39.0",
		"googleapis": "^171.4.0",
		"jose": "^6.2.2",
		"qrcode": "^1.5.4",
		"stripe": "^21.0.0",
		"zod": "^3.24.0"
	}
}
