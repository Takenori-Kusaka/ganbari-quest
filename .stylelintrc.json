{
	"extends": ["stylelint-config-standard"],
	"rules": {
		"color-no-hex": [
			true,
			{
				"message": "ハードコード hex 禁止。CSS変数 var(--color-*) を使用してください",
				"severity": "error"
			}
		],
		"declaration-no-important": [
			true,
			{
				"message": "!important 禁止。コンポーネント設計で解決してください"
			}
		],
		"at-rule-no-unknown": [
			true,
			{
				"ignoreAtRules": ["theme", "apply", "reference", "utility", "variant", "source", "tailwind"]
			}
		],
		"import-notation": null,
		"color-hex-length": null,
		"property-no-vendor-prefix": null,
		"rule-empty-line-before": null,
		"color-function-notation": null,
		"color-function-alias-notation": null,
		"alpha-value-notation": null,
		"custom-property-empty-line-before": null,
		"declaration-empty-line-before": null,
		"no-descending-specificity": null,
		"selector-class-pattern": null
	},
	"overrides": [
		{
			"files": ["src/lib/ui/styles/**/*.css"],
			"rules": {
				"color-no-hex": null,
				"declaration-no-important": null,
				"length-zero-no-unit": null
			}
		}
	],
	"ignoreFiles": ["node_modules/**", ".svelte-kit/**", "build/**", "site/**", "src/stories/**"]
}
