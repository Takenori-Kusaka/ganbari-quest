# Database
DATABASE_URL=./data/ganbari-quest.db

# Server
HOST=0.0.0.0
PORT=3000
# ORIGIN is auto-detected if not set (http://{HOST}:{PORT})
# Set explicitly if using a reverse proxy or custom domain:
# ORIGIN=http://192.168.1.100:3000

# Gemini API (avatar image generation - optional)
# GEMINI_API_KEY=your_gemini_api_key_here

# Backup (optional)
# BACKUP_DIR=./data/backups
# BACKUP_RETENTION=10
# BACKUP_POST_HOOK=node scripts/hooks/gdrive-upload.cjs

# Google Drive Backup hook (optional, used with BACKUP_POST_HOOK)
# GDRIVE_CLIENT_ID=your_client_id
# GDRIVE_CLIENT_SECRET=your_client_secret
# GDRIVE_REFRESH_TOKEN=your_refresh_token
# GDRIVE_FOLDER_ID=your_folder_id

# Cognito (production only)
# COGNITO_LOGOUT_URL=https://ganbari-quest.com/

# Logging
# LOG_LEVEL=info

# Discord Alert (optional - for 500 error notifications)
# DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
