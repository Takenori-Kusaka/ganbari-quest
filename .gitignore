# Dependencies
node_modules/

# Build output
.svelte-kit/
build/
dist/

# Environment
.env
.env.*
!.env.example

# Database
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.bak.*

# IDE
# #2183: .vscode/ は team 共有設定 (settings.json / extensions.json) のみ追跡。
# 個人 keybindings / launch.json / theme 等は ignore で個別除外
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Claude Code
.claude/settings.local.json
.claude/worktrees/
.playwright-mcp/

# OS
.DS_Store
Thumbs.db

# Test
coverage/
playwright-report/
playwright-report-demo/
test-results/
test-results.json
blob-report/
tests/e2e/.auth/
playwright/.auth/

# Drizzle (auto-generated by drizzle-kit push)
drizzle/

# Generated images (Gemini API)
static/generated/

# User uploads (avatars etc.)
static/uploads/

# Tenant-scoped files
static/tenants/

# CDK
infra/cdk.out/
infra/cdk.context.json

# Terraform (GCP)
infra/gcp/.terraform/
infra/gcp/*.tfstate
infra/gcp/*.tfstate.*
infra/gcp/*.tfvars
!infra/gcp/*.tfvars.example
infra/gcp/.terraform.lock.hcl

# Legacy tickets (migrated to GitHub Issues)
docs/tickets/

# Temporary files
tmp/
screenshots/
# LP screenshots are generated at GitHub Pages deploy time (#1157)
site/screenshots/
# docs/screenshots/ は git 追跡しない（PR 証跡は GitHub CDN にアップロード）
docs/screenshots/

# Reports (jscpd, type-coverage, security scan, etc.)
reports/

# LP metrics output (generated by scripts/measure-lp-dimensions.mjs, #1163)
lp-metrics.json

# Storybook
storybook-static/

# Misc
*.log
*.tsbuildinfo

# Logo candidates (deleted from history via git filter-repo in #1443)
docs/design/logo-candidates/

# PR証跡スクリーンショット（GitHub PR に直接アップロードすること。git管理不要）
docs/pr-screenshots/

# PR# プレフィックスの screenshots は screenshots ブランチに push（main 追跡禁止）
pr-*/

# 一時 screenshots / 旧 PR アセット / 孤児 sound は履歴から filter-repo で抹消済み（main 追跡禁止）
tmp-screenshots/
.tmp-screenshots/
.tmp-ss/
.tmp-ss-*/
.tmp-pr*/
.tmp-pr*-ss/
docs/pr-assets/
/sound/




