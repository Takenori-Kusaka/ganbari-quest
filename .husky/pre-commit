#!/usr/bin/env sh
# .husky/pre-commit (#2086)
#
# src/lib/domain/labels.ts / terms.ts 変更時の SSOT companion 整合検査。
#
# 同一構造の押し戻し (labels.ts edit → companion 再生成忘れ → CI で初めて発覚)
# が直近 3 件連続発生したため (#2075 / PR #2081 fix の 2 回連続)、pre-commit
# レイヤで構造的に検査する。
#
# 検査内容:
#   1. biome check                  (labels.ts / terms.ts の formatting / lint)
#   2. generate-lp-labels --check   (site/shared-labels.js が labels.ts と同期)
#   3. sync-lp-fallback --check     (site/*.html の fallback text が labels.ts と同期)
#
# 既存スクリプト再利用 (CI / npm run pre-ready と同じ gate)。
#
# 関連:
#   - ADR-0026 force push 禁止 / no-verify 禁止 (本 hook bypass は実害が大きい)
#   - ADR-0045 terms.ts SSOT 2 階層化原則
#   - docs/sessions/qa-session.md follow-up rule (同種問題 3 件以上で構造解消)
#
# Phase 2 (auto-fix mode): 本 hook では --check のみ実施し、自動 git add は行わない。
# 自動再生成 + git add は明示的ユーザ意図不在の副作用を生むため、別 Issue で議論する。
#
# bypass: --no-verify は禁止 (ADR-0026)。本 hook の存在意義を毀損する。

STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE "(src/lib/domain/labels\.ts|src/lib/domain/terms\.ts)"; then
  echo "[pre-commit] labels.ts / terms.ts 変更検出 — SSOT companion 整合検査を実行"

  echo "[pre-commit] (1/3) biome check src/lib/domain/labels.ts src/lib/domain/terms.ts"
  npx biome check src/lib/domain/labels.ts src/lib/domain/terms.ts || {
    echo "[pre-commit] biome check FAILED — 'npx biome check --write src/lib/domain/labels.ts src/lib/domain/terms.ts' で修正してください"
    exit 1
  }

  echo "[pre-commit] (2/3) node scripts/generate-lp-labels.mjs --check"
  node scripts/generate-lp-labels.mjs --check || {
    echo "[pre-commit] generate-lp-labels --check FAILED — 'node scripts/generate-lp-labels.mjs' で site/shared-labels.js を再生成して staging に追加してください"
    exit 1
  }

  echo "[pre-commit] (3/3) node scripts/sync-lp-fallback.mjs --check"
  node scripts/sync-lp-fallback.mjs --check || {
    echo "[pre-commit] sync-lp-fallback --check FAILED — 'node scripts/sync-lp-fallback.mjs' で site/*.html fallback を更新して staging に追加してください"
    exit 1
  }

  echo "[pre-commit] SSOT companion 整合検査 OK"
fi
